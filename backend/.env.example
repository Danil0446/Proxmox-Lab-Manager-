# Скопируйте в backend/.env и заполните. Файл backend/.env не коммитьте.
# Подробности: docs/SETUP_NEW_MACHINE.md и корневой README.md
# База (async): по умолчанию SQLite. Файл app.db создаётся в каталоге backend при старте.
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Proxmox API (HTTPS, порт 8006)
PROXMOX_API_URL=https://your-proxmox-host:8006
PROXMOX_TOKEN_ID=user@pve!tokenname
PROXMOX_TOKEN_SECRET=your-token-secret

# Имя ноды по умолчанию в кластере
PROXMOX_DEFAULT_NODE=debian

# Realm для учёток студентов (обычно pve)
PROXMOX_STUDENT_REALM=pve

# Роль в Proxmox с ограниченными правами (создайте в Datacenter → Permissions → Roles)
PROXMOX_STUDENT_ROLE=StudentRole
